{
  "name": "jobdone",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "npm --prefix frontend run build",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json",
    "test:backend": "npm --prefix backend test",
    "vercel:build:backend": "vercel --cwd backend build --prod",
    "vercel:build:frontend": "vercel --cwd frontend build --prod",
    "deploy:backend": "npm run vercel:build:backend && vercel --cwd backend deploy --prebuilt --prod --yes",
    "deploy:frontend": "npm run vercel:build:frontend && vercel --cwd frontend deploy --prebuilt --prod --yes",
    "deploy:prod": "npm run deploy:release",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:promote": "bash scripts/promote-staging-to-production.sh",
    "deploy:check:staging": "bash scripts/check-deploy.sh staging",
    "deploy:check:production": "bash scripts/check-deploy.sh production",
    "qa:staging": "QA_BASE_URL=https://jobdone-staging.vercel.app npm --prefix frontend run qa:smoke",
    "deploy:release": "npm run deploy:staging && npm run deploy:check:staging && npm run qa:staging && npm run deploy:promote && npm run deploy:check:production",
    "logs:backend": "bash scripts/tail-backend-prod-logs.sh",
    "auth:emails:dry-run": "node scripts/apply-supabase-auth-email-templates.js",
    "auth:emails:apply": "node scripts/apply-supabase-auth-email-templates.js --apply"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
