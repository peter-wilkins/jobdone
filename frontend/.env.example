# Backend API URL
# Default is http://localhost:3000 if not specified
VITE_API_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173

# Supabase (for magic link auth)
# Get these from: Supabase dashboard → Settings → API
# Use the "anon / public" key here — NOT the service_role key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Water Walk map tiles
# Quick test path: this key is public in browser builds because VITE_* values are bundled into frontend JS.
# Prefer backend proxying before treating this as production-secret infrastructure.
VITE_OS_MAPS_API_KEY=your-os-data-hub-key-here
VITE_OS_MAPS_LAYER=Outdoor_3857
VITE_OS_MAPS_MAX_ZOOM=20
# Optional full tile URL override, for example an internal/proxied tile endpoint.
# VITE_WATER_WALK_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_WATER_WALK_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors
