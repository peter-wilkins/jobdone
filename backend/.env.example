# Deepgram API (for transcription)
DEEPGRAM_API_KEY=your-key-here

# Anthropic API (for Claude summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (for embeddings)
VOYAGE_API_KEY=pa_...

# Supabase (optional - cloud sync disabled if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_SCHEMA=jobdone

# Postgres admin/task runner connection string.
# Use Supabase direct/session-pooler Postgres URL, not the anon API key.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# Server
PORT=3000
NODE_ENV=development

# Testing - set to true to mock API responses
USE_MOCK_APIS=false
