# Deepgram API (for transcription)
DEEPGRAM_API_KEY=your-key-here

# Anthropic API (for Claude summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (for embeddings)
VOYAGE_API_KEY=pa_...

# Supabase Auth (optional - login disabled if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres pooler URL (optional - cloud sync disabled if not set)
SUPABASE_DB_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
SUPABASE_DB_SCHEMA=jobdone

# Server
PORT=3000
NODE_ENV=development

# Testing - set to true to mock API responses
USE_MOCK_APIS=false
